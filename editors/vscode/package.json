{
  "name": "outmatch",
  "displayName": "Outmatch",
  "description": "Syntax highlighting for Outmatch (.om) test files",
  "version": "0.2.0",
  "publisher": "outmatch",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "outmatch",
        "aliases": ["Outmatch", "om"],
        "extensions": [".om"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "outmatch",
        "scopeName": "source.outmatch",
        "path": "./syntaxes/outmatch.tmLanguage.json"
      }
    ]
  }
}
